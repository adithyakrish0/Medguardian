# MedGuardian Environment Configuration
# Copy this file to .env and fill in your values

# Flask Configuration
SECRET_KEY=change-this-to-a-random-secret-key-in-production
FLASK_ENV=development
FLASK_DEBUG=True
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=your-bot-username

# Database Configuration - Using Session Pooler for IPv4 Compatibility
DATABASE_URL=postgresql://user:password@host:5432/database

# Email Configuration (for notifications)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@medguardian.com

# Security
WTF_CSRF_ENABLED=True
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# For Remote Tunnel Mode (Evaluator Demo), use these instead:
# SESSION_COOKIE_SECURE=True
# SESSION_COOKIE_SAMESITE=None
# CORS_ORIGINS=https://your-tunnel-url.trycloudflare.com

# Application Settings
MAX_CONTENT_LENGTH=16777216  # 16MB
UPLOAD_FOLDER=temp

# Vision System (YOLO-based medication/hand detection)
VISION_ENABLED=True
VISION_DISABLED=false
YOLO_MODEL_PATH=yolov8s-worldv2.pt
PILL_DETECTION_CONFIDENCE=0.5

# Scheduler
SCHEDULER_ENABLED=True
MISSED_DOSE_CHECK_INTERVAL=3600  # 1 hour in seconds

# Rate Limiting
RATELIMIT_ENABLED=True
RATELIMIT_STORAGE_URL=memory://

# Gemini Cloud API (used for chat fallback and other AI features)
GEMINI_API_KEY=your-gemini-api-key

# Chat Backend Toggle
# Options:
#   "gemini" - Use Gemini Cloud API directly. Fast, reliable, no local GPU needed.
#              Best for: demos, production, when ChromaDB is not populated.
#   "llama"  - Use local Llama 3.2-1B + ChromaDB RAG pipeline as primary.
#              Falls back to Gemini if RAG fails or has no knowledge docs.
#              Best for: offline use, privacy-sensitive deployments, when ChromaDB is populated.
CHAT_BACKEND=gemini
